# PROJECT: Number Guessing Game
# DESCRIPTION: User guesses a random number between 1 and 100

import random

secret = random.randint(1, 100)
attempts = 0

while True:
    guess = int(input("Guess the number (1-100): "))
    attempts += 1

    if guess < secret:
        print("Too low")
    elif guess > secret:
        print("Too high")
    else:
        print(f"Correct! Attempts: {attempts}")
        break
